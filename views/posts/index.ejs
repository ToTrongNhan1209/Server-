<div class="page-header">
  <div>
    <h1 class="page-header__title">Posts</h1>
    <p class="page-header__subtitle"><%= pagination.total %> total post<%= pagination.total === 1 ? '' : 's' %></p>
  </div>
  <a href="/posts/create" class="btn btn-primary">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    New Post
  </a>
</div>

<div class="card">
  <form class="toolbar" method="GET" action="/posts">
    <div class="toolbar__search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" name="q" value="<%= search %>" placeholder="Search posts by title..." data-live-search />
    </div>
    <select name="status" class="form-control" style="max-width: 170px;" onchange="this.form.submit()">
      <option value="" <%= status === '' ? 'selected' : '' %>>All Status</option>
      <option value="published" <%= status === 'published' ? 'selected' : '' %>>Published</option>
      <option value="draft" <%= status === 'draft' ? 'selected' : '' %>>Draft</option>
    </select>
    <% if (search || status) { %>
      <a href="/posts" class="btn btn-ghost btn-sm">Clear</a>
    <% } %>
  </form>

  <% if (posts && posts.length) { %>
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Title</th>
          <th>Category</th>
          <th>Status</th>
          <th>Created</th>
          <th style="text-align:right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% posts.forEach(function (post) { %>
        <tr>
          <td>
            <div class="cell-title">
              <% if (post.featured_image) { %>
                <img class="table-thumb" src="<%= post.featured_image %>" alt="">
              <% } else { %>
                <div class="table-thumb-placeholder">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-5-5L5 21"/></svg>
                </div>
              <% } %>
              <div class="cell-title__text">
<div class="cell-title__main">
    <a href="/posts/<%= post.id %>">
        <%= post.title %>
    </a>
</div>
                <div class="cell-title__sub">/<%= post.slug %></div>
              </div>
            </div>
          </td>
          <td><%= post.categories ? post.categories.name : '—' %></td>
          <td>
            <span class="badge badge--<%= post.status %>"><%= post.status === 'published' ? 'Published' : 'Draft' %></span>
          </td>
          <td class="text-muted"><%= new Date(post.created_at).toLocaleDateString() %></td>
          <td>
            <div class="row-actions">
              <a href="/posts/<%= post.id %>/edit" class="btn btn-outline btn-sm">Edit</a>
              <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" data-confirm="Delete “<%= post.title %>”? This cannot be undone.">
                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <%- include('../partials/pagination', {
    pagination: pagination,
    baseUrl: '/posts',
    queryParams: { q: search, status: status }
  }) %>

  <% } else { %>
  <div class="empty-state">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
    <h3>No posts found</h3>
    <p><%= search || status ? 'Try adjusting your search or filters.' : 'Create your first blog post to get started.' %></p>
    <a href="/posts/create" class="btn btn-primary">Create Post</a>
  </div>
  <% } %>
</div>
