<div class="page-header">
  <div>
    <h1 class="page-header__title">Dashboard</h1>
    <p class="page-header__subtitle">Overview of your blog content</p>
  </div>
  <a href="/posts/create" class="btn btn-primary">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    New Post
  </a>
</div>

<div class="stat-grid">
  <div class="stat-card stat-card--green">
    <div>
      <div class="stat-card__label">Total Posts</div>
      <div class="stat-card__value"><%= stats.totalPosts %></div>
    </div>
    <div class="stat-card__icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
    </div>
  </div>

  <div class="stat-card stat-card--blue">
    <div>
      <div class="stat-card__label">Total Categories</div>
      <div class="stat-card__value"><%= stats.totalCategories %></div>
    </div>
    <div class="stat-card__icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m20.59 13.41-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><circle cx="7" cy="7" r="1"/></svg>
    </div>
  </div>

  <div class="stat-card stat-card--slate">
    <div>
      <div class="stat-card__label">Published Posts</div>
      <div class="stat-card__value"><%= stats.publishedPosts %></div>
    </div>
    <div class="stat-card__icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    </div>
  </div>

  <div class="stat-card stat-card--amber">
    <div>
      <div class="stat-card__label">Draft Posts</div>
      <div class="stat-card__value"><%= stats.draftPosts %></div>
    </div>
    <div class="stat-card__icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
    </div>
  </div>
</div>

<div class="card">
  <h2 class="section-title">Recent Posts</h2>

  <% if (recentPosts && recentPosts.length) { %>
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Title</th>
          <th>Category</th>
          <th>Status</th>
          <th>Created</th>
        </tr>
      </thead>
      <tbody>
        <% recentPosts.forEach(function (post) { %>
        <tr>
          <td>
            <div class="cell-title">
              <% if (post.featured_image) { %>
                <img class="table-thumb" src="<%= post.featured_image %>" alt="">
              <% } else { %>
                <div class="table-thumb-placeholder">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-5-5L5 21"/></svg>
                </div>
              <% } %>
              <div class="cell-title__text">
                <div class="cell-title__main"><%= post.title %></div>
                <div class="cell-title__sub">/<%= post.slug %></div>
              </div>
            </div>
          </td>
          <td><%= post.categories ? post.categories.name : '—' %></td>
          <td>
            <span class="badge badge--<%= post.status %>"><%= post.status === 'published' ? 'Published' : 'Draft' %></span>
          </td>
          <td class="text-muted"><%= new Date(post.created_at).toLocaleDateString() %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } else { %>
  <div class="empty-state">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
    <h3>No posts yet</h3>
    <p>Create your first blog post to see it here.</p>
    <a href="/posts/create" class="btn btn-primary">Create Post</a>
  </div>
  <% } %>
</div>
