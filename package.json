{
  "name": "blog-cms-admin",
  "version": "1.0.0",
  "description": "Simple Blog CMS Admin Dashboard - Node.js, Express, EJS, SCSS, Supabase",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "build:css": "sass public/scss/main.scss public/css/main.css --style=compressed --no-source-map",
    "watch:css": "sass public/scss/main.scss public/css/main.css --watch"
  },
  "dependencies": {
    "@supabase/server": "^1.3.0",
    "@supabase/supabase-js": "^2.45.4",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "method-override": "^3.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "slugify": "^1.6.6",
    "tinymce": "^8.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "sass": "^1.77.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
